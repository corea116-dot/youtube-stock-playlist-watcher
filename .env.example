# YouTube Data API key.
# 실제 키를 여기에 넣지 말고, 로컬 환경변수나 GitHub Secrets에 등록하세요.
YOUTUBE_API_KEY=your_youtube_api_key_here

# Gemini API key for video-content summarization.
# 실제 키를 여기에 넣지 마세요. 로컬 환경변수나 GitHub Secrets에 등록하세요.
GEMINI_API_KEY=your_gemini_api_key_here

# Single YouTube playlist ID to watch.
# 단일 재생목록만 감시할 때 사용하는 기존 방식입니다.
# 예: https://www.youtube.com/playlist?list=PLAYLIST_ID_HERE 에서 list= 뒤의 값입니다.
PLAYLIST_ID=your_playlist_id_here

# Multiple YouTube playlist IDs to watch.
# 여러 재생목록을 감시할 때는 PLAYLIST_IDS 사용을 권장합니다.
# 전체 URL이 아니라 list= 뒤의 재생목록 ID만 쉼표로 연결하세요.
# 예: PLAYLIST_IDS=PLabc123,PLdef456,PLghi789
PLAYLIST_IDS=PLabc123,PLdef456,PLghi789

# SMTP server host for future email delivery.
# 예: Gmail은 smtp.gmail.com 을 사용할 수 있습니다.
SMTP_HOST=smtp.example.com

# SMTP server port. 숫자만 입력합니다.
# 예: 465 또는 587
SMTP_PORT=587

# SMTP login user. 보통 이메일 주소입니다.
SMTP_USER=your_email@example.com

# SMTP password or app password.
# 실제 비밀번호를 여기에 넣지 마세요.
SMTP_PASS=your_smtp_app_password_here

# Email address that will receive future summary emails.
EMAIL_TO=receiver@example.com

# Maximum number of recent playlist videos to check per run.
# 값을 비우면 프로그램 기본값 5를 사용합니다.
MAX_VIDEOS_TO_CHECK=5

# Gemini model name for summarization.
# 값을 비우면 프로그램 기본값을 사용합니다.
GEMINI_MODEL=gemini-2.5-flash-lite
